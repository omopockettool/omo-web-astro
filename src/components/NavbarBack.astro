---
interface Props {
  backLabel?: string;
  backHref?: string;
}
const { backLabel = 'OMO', backHref = '/' } = Astro.props;
---
<nav class="detail-navbar">
  <div class="navbar-content">
    <a href={backHref} class="back-button">
      <span class="back-arrow">←</span>
      <span>{backLabel}</span>
    </a>
    <div class="navbar-controls">
      <div class="lang-toggle" aria-label="Language selector">
        <button class="lang-button is-active" data-lang-switch="es" type="button">ES</button>
        <button class="lang-button" data-lang-switch="en" type="button">EN</button>
      </div>
      <button class="theme-toggle" data-theme-toggle type="button" aria-label="Toggle dark mode">
        <span class="theme-toggle-icon">☾</span>
      </button>
    </div>
  </div>
</nav>
