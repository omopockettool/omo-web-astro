---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  page: string;
}
const { title = 'OMO', page } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/assets/omo/omo-negro.png" />
    <link rel="apple-touch-icon" href="/assets/omo/omo-negro.png" />
    <link rel="shortcut icon" href="/assets/omo/omo-negro.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Alan+Sans:wght@300..900&display=swap" rel="stylesheet" />
    <ClientRouter />
    <script is:inline>
      (function() {
        function getTheme() {
          var t = localStorage.getItem('omo-theme');
          if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          return t === 'dark' ? 'dark' : 'light';
        }

        function applyThemeToDocument(doc) {
          doc.documentElement.dataset.theme = getTheme();
        }

        applyThemeToDocument(document);

        document.addEventListener('astro:before-swap', function(event) {
          if (event && event.newDocument) {
            applyThemeToDocument(event.newDocument);
          }
        });
      })();
    </script>
  </head>
  <body data-page={page} style="min-height:100vh;display:flex;flex-direction:column;">
    <slot />
    <script>
      import '../scripts/omo';
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
